# Copy to frontend/.env for local development.

# Dev-only: the notaire enrollment token, displayed in the home page "PoC" box
# so a reviewer can become notaire in one click. MUST match the backend's
# NOTAIRE_ENROLLMENT_TOKEN (in the repo-root .env) in development.
# In production this is never shipped to the browser — the token is an operator
# secret printed in the server logs.
VITE_NOTAIRE_ENROLLMENT_TOKEN=dev-notaire-token-poc-only
